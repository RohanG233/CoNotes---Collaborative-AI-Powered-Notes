PORT=3001
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/prepflow?retryWrites=true&w=majority
JWT_SECRET=replace_with_64_char_random_string
REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
