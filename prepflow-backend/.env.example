# ─────────────────────────────────────────────────────────────────
# PrepFlow Backend — Root .env (used by docker-compose)
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# MongoDB Atlas → Connect → Drivers → copy the connection string
# Include the database name: /prepflow?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/prepflow?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET and REFRESH_SECRET MUST be different strings
JWT_SECRET=replace_with_64_char_random_string
REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# ── AI ────────────────────────────────────────────────────────────
# Get from openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-...
# Any model slug from openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── CORS ──────────────────────────────────────────────────────────
# Local: http://localhost:5173
# Production: https://your-app.vercel.app (no trailing slash)
CLIENT_URL=http://localhost:5173

# ── Rate limiting (optional overrides) ───────────────────────────
AI_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_WINDOW_MS=3600000
